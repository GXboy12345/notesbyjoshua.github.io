---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
---

<StarlightPage frontmatter={{ title: 'Feedback and Requests', prev: false, next: false }}>
  <p>Use the form below to suggest topics, report mistakes, or ask for additions. Submissions go straight to me. Note that if you want to make a note about a specific page go to that page and then immediate go to this page again then submit your feedback.</p>
  <FeedbackForm />
</StarlightPage>
