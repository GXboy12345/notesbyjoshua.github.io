---
// Native feedback form -> Supabase `feedback` table (anyone may submit; admins read).
// A Supabase Database Webhook on INSERT calls the `feedback-to-linear` Edge
// Function, which opens a Linear ticket for every category except "praise".
// When opened from a per-note "Report an issue" link, ?from= / ?title= prefill
// the page context so the ticket links back to the exact note.
---
<form id="fb-form" class="fb-form">
  <label for="fb-category">What kind of feedback is this?</label>
  <select id="fb-category" required>
    <option value="" disabled selected>Choose one…</option>
    <option value="note-to-add">A note or topic to add</option>
    <option value="correction">A correction / something to fix</option>
    <option value="bug">A bug with the site</option>
    <option value="question">A question</option>
    <option value="praise">Just saying thanks</option>
  </select>

  <label for="fb-message">Your feedback, question, or request</label>
  <textarea id="fb-message" rows="5" required placeholder="What's on your mind?"></textarea>

  <label for="fb-name">Name (optional)</label>
  <input id="fb-name" type="text" maxlength="80" placeholder="So I know who to thank" />

  <p id="fb-context" class="fb-context" hidden></p>

  <button type="submit" class="account-btn">Send feedback</button>
  <p id="fb-msg" class="fb-msg" hidden></p>
</form>

<script>
  import { getSupabase } from '../lib/supabase';
  const sb = getSupabase();
  const form = document.getElementById('fb-form') as HTMLFormElement;
  const msg = document.getElementById('fb-msg')!;
  const category = document.getElementById('fb-category') as HTMLSelectElement;
  const message = document.getElementById('fb-message') as HTMLTextAreaElement;
  const name = document.getElementById('fb-name') as HTMLInputElement;
  const context = document.getElementById('fb-context')!;

  // Page context: prefer explicit ?from= / ?title= (set by per-note "Report an
  // issue" links); otherwise fall back to the referring page if it's this site.
  const params = new URLSearchParams(location.search);
  let pageUrl = params.get('from') || '';
  let pageTitle = params.get('title') || '';
  if (!pageUrl && document.referrer) {
    try {
      const ref = new URL(document.referrer);
      if (ref.origin === location.origin && ref.pathname !== '/feedback/') {
        pageUrl = ref.pathname;
      }
    } catch { /* ignore malformed referrer */ }
  }
  if (pageUrl) {
    context.textContent = `About: ${pageTitle || pageUrl}`;
    context.hidden = false;
  }

  function notify(text: string, ok: boolean) {
    msg.textContent = text;
    msg.dataset.ok = String(ok);
    msg.hidden = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!sb) { notify('Feedback is temporarily unavailable.', false); return; }
    const text = message.value.trim();
    if (!text || !category.value) return;
    const btn = form.querySelector('button')!;
    btn.setAttribute('disabled', 'true');
    try {
      const { data: { user } } = await sb.auth.getUser();
      const { error } = await sb.from('feedback').insert({
        message: text,
        name: name.value.trim() || null,
        category: category.value,
        page_url: pageUrl || null,
        page_title: pageTitle || null,
        user_id: user?.id ?? null,
      });
      if (error) throw error;
      form.reset();
      notify('Thanks! Your feedback was submitted.', true);
    } catch (err) {
      console.error('[feedback] submit failed:', err);
      notify('Sorry, that didn’t go through. Please try again.', false);
    } finally {
      btn.removeAttribute('disabled');
    }
  });
</script>
