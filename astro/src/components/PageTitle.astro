---
// Override of Starlight's PageTitle. Renders the default <h1>, and on note
// pages adds Bookmark + Mark-as-read toggles and an estimated reading time.
// A small client enhancement also colour-codes theorem boxes and turns
// practice "Solution" boxes into attempt-first collapsibles (all pages).
import Default from '@astrojs/starlight/components/PageTitle.astro';
const path = Astro.url.pathname;
const isNote = path.startsWith('/notes/');
// Source file of this note, repo-root relative (e.g. astro/src/content/docs/...),
// so the pencil can open the editor pre-loaded with this exact file. filePath is
// project-root relative (src/content/docs/...), so prefix astro/.
const filePath = (Astro.locals as any).starlightRoute?.entry?.filePath as string | undefined;
const editHref = isNote && filePath ? `/admin/edit?path=${encodeURIComponent(`astro/${filePath}`)}` : null;
---
<div class="page-title-row">
  <Default><slot /></Default>
  {isNote && (
    <div class="page-actions">
      <span class="page-meta" id="page-meta" hidden></span>
      {editHref && (
        <a class="edit-note-btn" href={editHref} title="Edit this note" aria-label="Edit this note" hidden>
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20h9" />
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
          </svg>
        </a>
      )}
      <button class="readmark-btn" type="button" data-slug={path} aria-pressed="false" hidden>
        <span class="readmark-check" aria-hidden="true">○</span>
        <span class="readmark-label">Mark read</span>
      </button>
      <button class="bookmark-btn" type="button" data-slug={path} aria-pressed="false" hidden>
        <span class="bookmark-star" aria-hidden="true">☆</span>
        <span class="bookmark-label">Bookmark</span>
      </button>
    </div>
  )}
</div>

<script>
  import { getSupabase, getRole } from '../lib/supabase';

  // --- Theorem boxes: colour-code by type; make solutions attempt-first. -----
  const TYPES: [RegExp, string][] = [
    [/^definition\b/i, 'def'],
    [/^theorem\b/i, 'thm'],
    [/^lemma\b/i, 'thm'],
    [/^corollary\b/i, 'thm'],
    [/^example\b/i, 'ex'],
    [/^proof\b/i, 'proof'],
    [/^solution\b/i, 'solution'],
  ];
  document.querySelectorAll<HTMLElement>('.theorem-box').forEach((box) => {
    const h = box.querySelector('h1,h2,h3,h4,h5,h6');
    const heading = h?.textContent?.trim() ?? '';
    const match = TYPES.find(([re]) => re.test(heading));
    if (match) box.classList.add('tb--' + match[1]);
    // Practice solutions start hidden behind a "Show solution" toggle.
    if (match && match[1] === 'solution') {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'solution-toggle';
      btn.setAttribute('aria-expanded', 'false');
      btn.textContent = 'Show ' + heading;
      box.hidden = true;
      box.parentNode?.insertBefore(btn, box);
      btn.addEventListener('click', () => {
        const opening = box.hidden;
        box.hidden = !opening;
        btn.textContent = (opening ? 'Hide ' : 'Show ') + heading;
        btn.setAttribute('aria-expanded', String(opening));
        btn.classList.toggle('is-open', opening);
      });
    }
  });

  // --- Reading time (note pages). --------------------------------------------
  const meta = document.getElementById('page-meta');
  if (meta) {
    const content = document.querySelector('.sl-markdown-content');
    const words = (content?.textContent || '').trim().split(/\s+/).filter(Boolean).length;
    const mins = Math.max(1, Math.round(words / 200));
    meta.textContent = `${mins} min read`;
    meta.hidden = false;
  }

  // --- Edit pencil (note pages, admins only). --------------------------------
  const sbEdit = getSupabase();
  const editBtn = document.querySelector<HTMLAnchorElement>('.edit-note-btn');
  if (sbEdit && editBtn) {
    sbEdit.auth.onAuthStateChange(async (_event, session) => {
      if (!session?.user) { editBtn.hidden = true; return; }
      try {
        if ((await getRole(session.user)) === 'admin') editBtn.hidden = false;
      } catch (err) {
        // Transient role-read failure: leave the pencil hidden (fail closed).
      }
    });
  }

  // --- Bookmark + Mark-as-read (note pages, signed in). ----------------------
  const sb = getSupabase();
  const bookmarkBtn = document.querySelector<HTMLButtonElement>('.bookmark-btn');
  const readBtn = document.querySelector<HTMLButtonElement>('.readmark-btn');
  if (sb && bookmarkBtn && readBtn) {
    const slug = bookmarkBtn.dataset.slug!;
    const title = document.querySelector('h1')?.textContent?.trim() || slug;
    const star = bookmarkBtn.querySelector<HTMLElement>('.bookmark-star')!;
    const bLabel = bookmarkBtn.querySelector<HTMLElement>('.bookmark-label')!;
    const check = readBtn.querySelector<HTMLElement>('.readmark-check')!;
    const rLabel = readBtn.querySelector<HTMLElement>('.readmark-label')!;
    let bookmarked = false;
    let read = false;
    let uid: string | null = null;

    const render = () => {
      star.textContent = bookmarked ? '★' : '☆';
      bLabel.textContent = bookmarked ? 'Bookmarked' : 'Bookmark';
      bookmarkBtn.setAttribute('aria-pressed', String(bookmarked));
      bookmarkBtn.classList.toggle('is-on', bookmarked);
      check.textContent = read ? '●' : '○';
      rLabel.textContent = read ? 'Read' : 'Mark read';
      readBtn.setAttribute('aria-pressed', String(read));
      readBtn.classList.toggle('is-on', read);
    };

    bookmarkBtn.addEventListener('click', async () => {
      if (!uid) return;
      const next = !bookmarked;
      bookmarkBtn.disabled = true;
      try {
        if (next) {
          const { error } = await sb.from('bookmarks').upsert({ user_id: uid, slug, title });
          if (error) throw error;
        } else {
          const { error } = await sb.from('bookmarks').delete().eq('user_id', uid).eq('slug', slug);
          if (error) throw error;
        }
        bookmarked = next;
        render();
      } catch (err) {
        console.error('[bookmark] toggle failed:', err);
      } finally {
        bookmarkBtn.disabled = false;
      }
    });

    readBtn.addEventListener('click', async () => {
      if (!uid) return;
      const next = !read;
      readBtn.disabled = true;
      try {
        if (next) {
          const { error } = await sb.from('read_notes').upsert({ user_id: uid, slug });
          if (error) throw error;
        } else {
          const { error } = await sb.from('read_notes').delete().eq('user_id', uid).eq('slug', slug);
          if (error) throw error;
        }
        read = next;
        render();
      } catch (err) {
        console.error('[read] toggle failed:', err);
      } finally {
        readBtn.disabled = false;
      }
    });

    sb.auth.onAuthStateChange(async (_event, session) => {
      if (!session?.user) { bookmarkBtn.hidden = true; readBtn.hidden = true; return; }
      uid = session.user.id;
      bookmarkBtn.hidden = false;
      readBtn.hidden = false;
      try {
        const [bm, rn] = await Promise.all([
          sb.from('bookmarks').select('slug').eq('slug', slug).maybeSingle(),
          sb.from('read_notes').select('slug').eq('slug', slug).maybeSingle(),
        ]);
        bookmarked = !!bm.data;
        read = !!rn.data;
        render();
      } catch (err) {
        console.error('[page] state load failed:', err);
      }
    });
  }
</script>
