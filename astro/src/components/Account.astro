---
// Auth UI. All logic runs client-side against Supabase (protected by RLS).
---
<div class="account">
  <p id="account-status">Loading…</p>

  <div id="account-signedout" hidden>
    <p>Sign in to track your progress and access your dashboard.</p>
    <button id="google-signin" class="account-btn">Sign in with Google</button>
  </div>

  <div id="account-signedin" hidden>
    <p>Signed in as <strong id="account-email"></strong> — role: <span id="account-role"></span>.</p>
    <p><a href="/dashboard/">View your reading dashboard →</a></p>
    <p id="admin-links" hidden><a href="/admin/">Open the admin dashboard →</a></p>
    <button id="signout" class="account-btn account-btn--secondary">Sign out</button>
  </div>

  <p id="account-disabled" hidden>Accounts aren’t configured yet (missing Supabase credentials).</p>
</div>

<script>
  import { getSupabase, getRole } from '../lib/supabase';

  const byId = (id: string) => document.getElementById(id)!;
  const STATES = ['account-status', 'account-signedout', 'account-signedin', 'account-disabled'];
  // Show exactly one top-level state block.
  const show = (id: string) => STATES.forEach((s) => (byId(s).hidden = s !== id));
  const sb = getSupabase();

  function update(session: any) {
    if (session?.user) {
      byId('account-email').textContent = session.user.email ?? '';
      byId('account-role').textContent = '…';
      show('account-signedin');
      // Role is best-effort; never let it block the signed-in UI.
      getRole()
        .then((role) => {
          byId('account-role').textContent = role ?? 'visitor';
          byId('admin-links').hidden = role !== 'admin';
        })
        .catch(() => { byId('account-role').textContent = 'visitor'; });
    } else {
      show('account-signedout');
    }
  }

  if (!sb) {
    show('account-disabled');
  } else {
    // Drive the UI from auth events. onAuthStateChange emits the current session
    // immediately (INITIAL_SESSION) without using getSession(), which can hang on
    // the auth lock. A timeout guarantees we never stay stuck on "Loading…".
    let settled = false;
    sb.auth.onAuthStateChange((_event, session) => {
      settled = true;
      update(session);
    });
    setTimeout(() => {
      if (!settled) {
        console.warn('[account] auth init slow; defaulting to signed-out');
        show('account-signedout');
      }
    }, 2500);
  }

  byId('google-signin')?.addEventListener('click', () => {
    sb?.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: window.location.origin + '/account/',
        // Always show Google's account chooser instead of silently reusing the
        // last-used account.
        queryParams: { prompt: 'select_account' },
      },
    });
  });

  byId('signout')?.addEventListener('click', async () => {
    try { await sb?.auth.signOut(); } catch (err) { console.error('[account] signout failed:', err); }
    update(null); // onAuthStateChange also fires SIGNED_OUT; this is a safety net
  });
</script>
