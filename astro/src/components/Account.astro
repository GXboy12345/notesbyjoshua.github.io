---
import notesSidebar from '../sidebar.json';
type Item = { label?: string; link?: string; items?: Item[] };

// Flatten the sidebar into sections of trackable notes (same rule as the
// dashboard: subject landing pages "<Subject> Home" aren't tracked).
function collect(items: Item[], heading: string) {
  const sections: { heading: string; slugs: string[] }[] = [];
  const direct: string[] = [];
  const groups: Item[] = [];
  for (const it of items) {
    if (it.items) groups.push(it);
    else if (it.link && !it.label?.endsWith(' Home')) direct.push(it.link);
  }
  if (direct.length) sections.push({ heading, slugs: direct });
  for (const g of groups) sections.push(...collect(g.items!, g.label ?? ''));
  return sections;
}
const sections = collect(notesSidebar as Item[], 'Notes');
const totalNotes = sections.reduce((n, s) => n + s.slugs.length, 0);
---
<div class="account" data-total-notes={totalNotes}>
  <p id="account-status">Loading…</p>

  <div id="account-signedout" hidden>
    <p>Sign in to track your progress and manage your profile.</p>
    <button id="google-signin" class="account-btn">Sign in with Google</button>
  </div>

  <div id="account-signedin" hidden>
    <div class="acct-id">
      <div class="acct-avatar-wrap">
        <img id="account-avatar" class="acct-avatar" alt="" hidden />
        <label class="acct-avatar-edit">
          Change
          <input id="account-avatar-input" type="file" accept="image/*" hidden />
        </label>
      </div>
      <div>
        <strong id="account-name" class="acct-name"></strong>
        <span id="account-since" class="acct-since"></span>
        <span id="account-avatar-msg" class="profile-save-msg" hidden></span>
      </div>
    </div>

    <h2>Profile</h2>
    <dl class="profile-fields">
      <div><dt>Email</dt><dd id="account-email"></dd></div>
      <div><dt>Role</dt><dd id="account-role"></dd></div>
    </dl>

    <div class="profile-field">
      <label for="account-username">Username</label>
      <div class="profile-row">
        <input id="account-username" type="text" maxlength="40" placeholder="Your display name" />
        <button id="account-save" class="account-btn" type="button">Save</button>
      </div>
      <p id="account-save-msg" class="profile-save-msg" hidden></p>
    </div>

    <h2>Your reading progress</h2>
    <p class="profile-progress"><strong id="account-readcount">0</strong> / {totalNotes} notes read</p>
    <span class="np-bar profile-bar"><span id="account-readbar" class="np-bar__fill" style="width:0%"></span></span>

    <div class="acct-breakdown">
      {sections.map((s) => (
        <div class="acct-subj" data-slugs={JSON.stringify(s.slugs)}>
          <span class="acct-subj-name">{s.heading}</span>
          <span class="np-bar acct-subj-bar"><span class="np-bar__fill" style="width:0%"></span></span>
          <span class="acct-subj-count">0 / {s.slugs.length}</span>
        </div>
      ))}
    </div>

    <p><a href="/dashboard/">Open your reading dashboard →</a></p>

    <p id="admin-links" hidden><a href="/admin/">Open the admin dashboard →</a></p>
    <p><button id="signout" class="account-btn account-btn--secondary" type="button">Sign out</button></p>
  </div>

  <p id="account-disabled" hidden>Accounts aren’t configured yet (missing Supabase credentials).</p>
</div>

<script>
  import { getSupabase, getProfile } from '../lib/supabase';

  const byId = (id: string) => document.getElementById(id)!;
  const STATES = ['account-status', 'account-signedout', 'account-signedin', 'account-disabled'];
  const show = (id: string) => STATES.forEach((s) => (byId(s).hidden = s !== id));
  const sb = getSupabase();
  const total = Number(document.querySelector('.account')?.getAttribute('data-total-notes') || 0);
  const pct = (read: number, all: number) => (all ? Math.round((read / all) * 100) : 0);
  let uid: string | null = null;

  byId('google-signin')?.addEventListener('click', () => {
    sb?.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: window.location.origin + '/account/', queryParams: { prompt: 'select_account' } },
    });
  });

  byId('signout')?.addEventListener('click', async () => {
    try { await sb?.auth.signOut(); } catch (err) { console.error('[account] signout failed:', err); }
    show('account-signedout');
  });

  async function saveUsername() {
    if (!sb || !uid) return;
    const value = (byId('account-username') as HTMLInputElement).value.trim();
    const msg = byId('account-save-msg');
    byId('account-save').setAttribute('disabled', 'true');
    try {
      const { error } = await sb.from('profiles').update({ display_name: value || null }).eq('id', uid);
      if (error) throw error;
      msg.textContent = 'Saved.';
      byId('account-name').textContent = value || (byId('account-email').textContent || '').split('@')[0];
    } catch (err) {
      console.error('[account] save failed:', err);
      msg.textContent = 'Could not save — try again.';
    } finally {
      msg.hidden = false;
      byId('account-save').removeAttribute('disabled');
      setTimeout(() => { msg.hidden = true; }, 2500);
    }
  }
  byId('account-save')?.addEventListener('click', saveUsername);

  // Upload a custom profile picture to the avatars bucket, then save its URL.
  byId('account-avatar-input')?.addEventListener('change', async (e) => {
    const input = e.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file || !sb || !uid) return;
    const msg = byId('account-avatar-msg');
    msg.textContent = 'Uploading…';
    msg.hidden = false;
    const detail = (err: any) => err?.message || err?.error_description || String(err);
    try {
      const ext = (file.name.split('.').pop() || 'png').toLowerCase();
      const path = `${uid}/avatar.${ext}`;
      const { error: upErr } = await sb.storage
        .from('avatars')
        .upload(path, file, { upsert: true, contentType: file.type });
      // Surface the real reason: a missing upload policy reads as a row-level
      // security error; a missing bucket reads as "Bucket not found".
      if (upErr) throw new Error('Storage upload failed — ' + detail(upErr));
      const { data: pub } = sb.storage.from('avatars').getPublicUrl(path);
      const url = `${pub.publicUrl}?t=${Date.now()}`; // cache-bust on change
      const { error: updErr } = await sb.from('profiles').update({ avatar_url: url }).eq('id', uid);
      if (updErr) throw new Error('Saving avatar_url failed — ' + detail(updErr));
      const avatar = byId('account-avatar') as HTMLImageElement;
      avatar.src = url;
      avatar.hidden = false;
      msg.textContent = 'Picture updated.';
    } catch (err) {
      console.error('[account] avatar upload failed:', err);
      msg.textContent = detail(err);
    } finally {
      input.value = '';
      setTimeout(() => { msg.hidden = true; }, 8000);
    }
  });

  // getProfile rejects on a transient read failure; retry a couple of times
  // before giving up so the page doesn't briefly assert "visitor".
  async function loadProfile(tries = 3) {
    for (let i = 0; i < tries; i++) {
      try { return await getProfile(); }
      catch (err) {
        if (i === tries - 1) { console.error('[account] profile load failed:', err); return null; }
        await new Promise((r) => setTimeout(r, 500));
      }
    }
    return null;
  }

  async function loadSignedIn(session: any) {
    uid = session.user.id;
    show('account-signedin');
    const profile = await loadProfile();
    const email = profile?.email ?? session.user.email ?? '';
    byId('account-email').textContent = email;
    // Only assert a role once we actually read the profile; otherwise leave the
    // current text rather than flashing "visitor".
    if (profile) {
      byId('account-role').textContent = profile.role;
      (byId('account-username') as HTMLInputElement).value = profile.display_name ?? '';
      byId('admin-links').hidden = profile.role !== 'admin';
    }
    byId('account-name').textContent = profile?.display_name || email.split('@')[0] || 'Account';

    // Avatar: custom upload wins, else the OAuth provider (Google) picture.
    const meta = session.user.user_metadata || {};
    const avatarUrl = profile?.avatar_url || meta.avatar_url || meta.picture;
    const avatar = byId('account-avatar') as HTMLImageElement;
    if (avatarUrl) { avatar.src = avatarUrl; avatar.hidden = false; }

    // Member since.
    if (profile?.created_at) {
      const d = new Date(profile.created_at);
      byId('account-since').textContent =
        'Member since ' + d.toLocaleDateString(undefined, { year: 'numeric', month: 'short' });
    }

    // Reading progress, overall + per subject.
    try {
      const { data, error } = await sb!.from('read_notes').select('slug');
      if (error) throw error;
      const readSet = new Set((data ?? []).map((r: any) => r.slug));
      const read = readSet.size;
      byId('account-readcount').textContent = String(read);
      byId('account-readbar').style.width = pct(read, total) + '%';
      document.querySelectorAll<HTMLElement>('.acct-subj').forEach((row) => {
        const slugs: string[] = JSON.parse(row.dataset.slugs || '[]');
        const r = slugs.filter((s) => readSet.has(s)).length;
        const countEl = row.querySelector('.acct-subj-count');
        if (countEl) countEl.textContent = `${r} / ${slugs.length}`;
        const fill = row.querySelector<HTMLElement>('.np-bar__fill');
        if (fill) fill.style.width = pct(r, slugs.length) + '%';
      });
    } catch (err) {
      console.error('[account] progress snapshot failed:', err);
    }
  }

  if (!sb) {
    show('account-disabled');
  } else {
    let settled = false;
    sb.auth.onAuthStateChange((_event, session) => {
      settled = true;
      session?.user ? loadSignedIn(session) : show('account-signedout');
    });
    setTimeout(() => { if (!settled) show('account-signedout'); }, 2500);
  }
</script>
