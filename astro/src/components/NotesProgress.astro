---
// Admin-only notes-completion report, grouped by course/topic. Data is generated
// at build time by scripts/notes_progress.py; this page is gated to admins.
import data from '../data/notes-progress.json';
import notesSidebar from '../sidebar.json';

type Page = {
  title: string; route: string; course: string; kind: string;
  status: string; progress: number; issues: string[]; next_step: string;
};
const { summary, pages } = data as { summary: Record<string, number | string>; pages: Page[] };

// Kept in sync with COURSE_RENAME in scripts/notes_progress.py.
const courseRename: Record<string, string> = {
  'Physics Competition Prep': 'Physics',
  'Chemistry Competition Prep': 'Chemistry',
};

// Subject landing pages are labelled "<Subject> Home" in the sidebar; collect
// their routes so they can be dropped from the report (they aren't units).
const isHomeLabel = (label: string) => label.endsWith(' Home');
const homeRoutes = new Set<string>();
(function collectHomes(items: any[]) {
  for (const it of items) {
    if (it.items) collectHomes(it.items);
    else if (it.link && isHomeLabel(it.label)) homeRoutes.add(it.link);
  }
})(notesSidebar as any[]);

// Course order as it appears in the sidebar.
const courseOrder: string[] = [];
(function walk(items: any[], label: string) {
  let hasLeaf = false;
  for (const it of items) {
    if (it.items) walk(it.items, it.label);
    else if (it.link && !isHomeLabel(it.label)) hasLeaf = true;
  }
  const name = courseRename[label] ?? label;
  if (hasLeaf && name && !courseOrder.includes(name)) courseOrder.push(name);
})(notesSidebar as any[], 'Notes');

// Group pages by course, least-done first within each group; skip home pages.
const byCourse: Record<string, Page[]> = {};
for (const p of pages) {
  if (homeRoutes.has(p.route)) continue;
  (byCourse[p.course] ||= []).push(p);
}
for (const list of Object.values(byCourse)) list.sort((a, b) => a.progress - b.progress);

const orderedCourses = [
  ...courseOrder.filter((c) => byCourse[c]),
  ...Object.keys(byCourse).filter((c) => !courseOrder.includes(c)),
];
const sections = orderedCourses
  // Drop catch-all groups that hold only landing/overview pages (e.g. "AP",
  // "Notes") — they aren't real courses to track.
  .filter((name) => byCourse[name].some((p) => p.kind !== 'index'))
  .map((name) => {
    const list = byCourse[name];
    const avg = Math.round(list.reduce((n, p) => n + p.progress, 0) / list.length);
    return { name, avg, pages: list };
  });
---

<div class="np">
  <p id="np-status">Loading…</p>

  <div id="np-denied" hidden>
    <p>This page is for admins only. <a href="/account/">Go to your account</a> to sign in.</p>
  </div>

  <div id="np-content" hidden>
    <p class="np-summary">
      Generated {summary.generated_at} · <strong>{summary.unit_pages}</strong> unit pages ·
      <strong>{summary.average_progress}%</strong> average ·
      <strong>{summary.below_complete}</strong> below complete ·
      <strong>{summary.with_placeholders}</strong> with placeholders
    </p>
    <p class="np-note">Auto-scored from page content. Grouped by topic; least-done first within each.</p>

    {sections.map((section) => (
      <section class="np-section">
        <details class="np-collapse" open>
          <summary class="np-section-head">
            <h2>{section.name} <span class="np-section-avg">{section.avg}% avg</span></h2>
          </summary>
          <div class="table-scroll">
          <table class="np-table">
            <thead>
              <tr><th>Page</th><th>Status</th><th>Progress</th><th>Main issues</th><th>Next step</th></tr>
            </thead>
            <tbody>
              {section.pages.map((p) => (
                <tr>
                  <td><a href={p.route}>{p.title}</a></td>
                  <td><span class={`note-status note-status--${p.status}`}>{p.status}</span></td>
                  <td>
                    <span class="np-bar" aria-label={`${p.progress}%`}>
                      <span class="np-bar__fill" style={`width:${p.progress}%`}></span>
                      <span class="np-bar__label">{p.progress}%</span>
                    </span>
                  </td>
                  <td>{p.issues.length ? p.issues.join(', ') : 'none flagged'}</td>
                  <td>{p.next_step}</td>
                </tr>
              ))}
            </tbody>
          </table>
          </div>
        </details>
      </section>
    ))}
  </div>
</div>

<script>
  import { getSupabase, getRole } from '../lib/supabase';
  const byId = (id: string) => document.getElementById(id)!;
  const show = (id: string) => ['np-status', 'np-denied', 'np-content'].forEach((s) => (byId(s).hidden = s !== id));
  const sb = getSupabase();

  async function gate(session: any) {
    if (!session?.user) { show('np-denied'); return; }
    // Pass the session user (no auth-method call inside this callback) and retry
    // a transient read so we never get stuck on "Loading…" or wrongly deny.
    for (let i = 0; i < 3; i++) {
      try {
        const role = await getRole(session.user);
        show(role === 'admin' ? 'np-content' : 'np-denied');
        return;
      } catch (err) {
        if (i === 2) { console.error('[np] role check failed:', err); show('np-denied'); }
        else await new Promise((r) => setTimeout(r, 400));
      }
    }
  }

  if (!sb) {
    show('np-denied');
  } else {
    let settled = false;
    sb.auth.onAuthStateChange((_event, session) => { settled = true; gate(session); });
    setTimeout(() => { if (!settled) show('np-denied'); }, 2500);
  }
</script>
