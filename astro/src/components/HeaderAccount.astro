---
// Header account control: a "Sign in" link when signed out, or a dropdown menu
// (Dashboard / Account / Admin / Sign out) when signed in. Plus social icons.
// Starlight renders this slot twice (desktop + mobile), so we use classes (not
// ids) and wire every instance. The resolved state is cached in localStorage and
// applied synchronously on load to avoid a flash of "Sign in"/wrong name on each
// page navigation.
import Default from '@astrojs/starlight/components/SocialIcons.astro';
import notesSidebar from './../sidebar.json';

// Total trackable notes (excludes "<Subject> Home" landing pages), used for the
// "% read" line in the menu.
type Item = { label?: string; link?: string; items?: Item[] };
const countLeaves = (items: Item[]): number =>
  items.reduce((n, it) => n + (it.items ? countLeaves(it.items) : it.link && !it.label?.endsWith(' Home') ? 1 : 0), 0);
const totalNotes = countLeaves(notesSidebar as Item[]);
---

<div class="header-account" data-total={totalNotes}>
  <a class="header-account-link ha-signin" href="/account/" hidden>Sign in</a>

  <div class="header-account-menu-wrap ha-wrap" hidden>
    <button class="header-account-link ha-toggle" aria-haspopup="true" aria-expanded="false">
      <span class="header-account-dot"></span>
      <span class="ha-name">Account</span>
    </button>
    <div class="header-account-menu ha-menu" hidden>
      <span class="ha-stats" hidden></span>
      <a href="/dashboard/">My Dashboard</a>
      <a href="/practiceproblems/practice/">Practice Problems</a>
      <a href="/feedback/">Feedback</a>
      <a href="/account/">Account</a>
      <a class="ha-admin" href="/admin/" hidden>Admin</a>
      <button type="button" class="ha-signout">Sign out</button>
    </div>
  </div>
</div>
<Default><slot /></Default>

<script>
  import { getSupabase, getProfile } from '../lib/supabase';

  const CACHE_KEY = 'notes-hdr';
  type State = { in: boolean; name?: string; admin?: boolean; pct?: number };

  const sb = getSupabase();
  const roots = Array.from(document.querySelectorAll<HTMLElement>('.header-account'));
  const total = Number(roots[0]?.dataset.total || 0);

  function wire(root: HTMLElement) {
    const signin = root.querySelector<HTMLElement>('.ha-signin')!;
    const wrap = root.querySelector<HTMLElement>('.ha-wrap')!;
    const toggle = root.querySelector<HTMLElement>('.ha-toggle')!;
    const menu = root.querySelector<HTMLElement>('.ha-menu')!;
    const nameEl = root.querySelector<HTMLElement>('.ha-name')!;
    const statsEl = root.querySelector<HTMLElement>('.ha-stats')!;
    const adminEl = root.querySelector<HTMLElement>('.ha-admin')!;
    const signout = root.querySelector<HTMLElement>('.ha-signout')!;
    const close = () => { menu.hidden = true; toggle.setAttribute('aria-expanded', 'false'); };

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const willOpen = menu.hidden;
      menu.hidden = !willOpen;
      toggle.setAttribute('aria-expanded', String(willOpen));
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    signout.addEventListener('click', async () => {
      try { await sb!.auth.signOut(); } catch (err) { console.error('[header] signout failed:', err); }
      close();
    });
    return { signin, wrap, toggle, menu, nameEl, statsEl, adminEl, close };
  }

  if (sb && roots.length) {
    const instances = roots.map(wire);

    const apply = (s: State | null) => {
      for (const i of instances) {
        if (s?.in) {
          i.signin.hidden = true;
          i.wrap.hidden = false;
          i.nameEl.textContent = s.name || 'Account';
          i.adminEl.hidden = !s.admin;
          if (typeof s.pct === 'number') { i.statsEl.textContent = `${s.pct}% read`; i.statsEl.hidden = false; }
          else i.statsEl.hidden = true;
        } else if (s) {
          i.signin.hidden = false;
          i.wrap.hidden = true;
          i.close();
        } else {
          // Unknown yet: keep both hidden so we never flash the wrong control.
          i.signin.hidden = true;
          i.wrap.hidden = true;
        }
      }
    };

    // Apply last-known state immediately (no flash on navigation).
    let cached: State | null = null;
    try { cached = JSON.parse(localStorage.getItem(CACHE_KEY) || 'null'); } catch {}
    apply(cached);

    document.addEventListener('click', (e) => {
      for (const i of instances) if (!i.menu.hidden && !i.wrap.contains(e.target as Node)) i.close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') instances.forEach((i) => i.close());
    });

    const save = (s: State) => {
      apply(s);
      try { localStorage.setItem(CACHE_KEY, JSON.stringify(s)); } catch {}
    };

    const readCount = async () => {
      const { count } = await sb.from('read_notes').select('*', { count: 'exact', head: true });
      return count ?? 0;
    };

    sb.auth.onAuthStateChange((_event, session) => {
      const user = session?.user;
      if (!user) { save({ in: false }); return; }
      const prefix = user.email ? user.email.split('@')[0] : 'Account';
      // Show immediately using the cached values (avoids the email-prefix flash).
      apply({ in: true, name: cached?.name || prefix, admin: cached?.admin, pct: cached?.pct });
      // getProfile() rejects on a transient read failure; only OVERWRITE the
      // cached state on a confident success, so a hiccup never demotes you to
      // "visitor"/the email prefix and then persists it via localStorage.
      Promise.all([getProfile(), readCount().catch(() => null)])
        .then(([p, cnt]) => {
          if (!p) return; // signed out between events — leave it to the next event
          const pct = cnt != null && total ? Math.round((cnt / total) * 100) : cached?.pct;
          save({ in: true, name: p.display_name || prefix, admin: p.role === 'admin', pct });
        })
        .catch((err) => console.warn('[header] profile refresh failed; keeping cached state', err));
    });
  }
</script>
