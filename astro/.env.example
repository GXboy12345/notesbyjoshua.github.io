# Supabase connection (Project Settings -> API in the Supabase dashboard).
# Copy this file to .env and fill in your project's values.
# Both are PUBLIC/anon values, safe to expose in the browser (protected by RLS).
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
