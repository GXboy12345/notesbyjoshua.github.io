---
import BaseLayout from './BaseLayout.astro';
import DocSidebar from '../components/DocSidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import MathRender from '../components/MathRender.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  /** Legacy client KaTeX pass when SSR math is off. */
  math?: boolean;
  /** Practice MCQs, figures lightbox, etc. */
  interactive?: boolean;
}

const { title, description, headings = [], math = false, interactive = false } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="layout-doc">
    <DocSidebar current={Astro.url.pathname} />
    <main class="doc-main" transition:animate="fade">
      <article class="prose">
        <slot />
      </article>
    </main>
    <TableOfContents headings={headings} />
  </div>
  {math && <MathRender />}
  {
    interactive && (
      <script>
        import { initDocPractice } from '../scripts/doc-practice.ts';
        import { initDocLightbox } from '../scripts/doc-lightbox.ts';

        initDocPractice();
        initDocLightbox();
        document.addEventListener('astro:page-load', () => {
          initDocPractice();
          initDocLightbox();
        });
      </script>
    )
  }
</BaseLayout>
