---
import BaseLayout from './BaseLayout.astro';
import DocSidebar from '../components/DocSidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import MathRender from '../components/MathRender.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  /** Legacy client KaTeX pass when SSR math is off. */
  math?: boolean;
  /** Practice MCQs, figures lightbox, etc. */
  interactive?: boolean;
  /** Personal annotations (notes collection). */
  annotations?: boolean;
  pageId?: string;
  pageTitle?: string;
  contentHash?: string;
  /** Hide from search engines (dev/orphan pages). */
  noindex?: boolean;
}

const {
  title,
  description,
  headings = [],
  math = false,
  interactive = false,
  annotations = false,
  pageId = '',
  pageTitle = '',
  contentHash = '',
  noindex = false,
} = Astro.props;
---

<BaseLayout title={title} description={description} noindex={noindex}>
  <div class="layout-doc">
    <DocSidebar current={Astro.url.pathname} />
    <main class="doc-main" transition:animate="fade">
      <div class="doc-main__canvas-wrap" aria-hidden="true">
        <canvas class="doc-main__canvas"></canvas>
      </div>
      <article
        class="prose"
        {...annotations && {
          'data-annotation-root': true,
          'data-page-id': pageId,
          'data-page-title': pageTitle,
          'data-content-hash': contentHash,
        }}
      >
        <slot />
      </article>
    </main>
    <TableOfContents headings={headings} />
  </div>
  {math && <MathRender />}
  <script>
    import { bindDocCanvasParallax } from '../scripts/doc-canvas-parallax.ts';

    bindDocCanvasParallax();
  </script>
  <script>
    import { initDocMinimap } from '../scripts/doc-minimap.ts';

    initDocMinimap();
    document.addEventListener('astro:page-load', () => {
      initDocMinimap();
    });
  </script>
  {
    annotations && (
      <script>
        import { initDocAnnotations } from '../scripts/doc-annotations.ts';

        initDocAnnotations();
        document.addEventListener('astro:page-load', () => {
          initDocAnnotations();
        });
      </script>
    )
  }
  {
    interactive && (
      <>
        <script>
          import { initDocPractice } from '../scripts/doc-practice.ts';
          import { initDocLightbox } from '../scripts/doc-lightbox.ts';

          initDocPractice();
          initDocLightbox();
        </script>
      </>
    )
  }
</BaseLayout>
