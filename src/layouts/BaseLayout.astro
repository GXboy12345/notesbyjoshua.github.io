---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';
import FontPreload from '../components/FontPreload.astro';
import ThemeScript from '../components/ThemeScript.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ReferenceSheetDrawer from '../components/ReferenceSheetDrawer.astro';
import { p } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { title = 'Notes by Joshua', description = 'Math, physics, and AP study notes', noindex = false } = Astro.props;
const fullTitle = title === 'Notes by Joshua' ? title : `${title} · Notes by Joshua`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <ThemeScript />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <FontPreload />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{fullTitle}</title>
    <ClientRouter />
    <link rel="icon" type="image/jpeg" href={p('/assets/Images/favicon.jpeg')} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-868QCS9DJP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-868QCS9DJP');
    </script>
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader current={Astro.url.pathname} />
      <ReferenceSheetDrawer />
      <slot />
      <footer class="site-footer">
        <p>
          <a href={p('/about/')}>Notes by Joshua</a>
          {' | '}
          Site Design Garret Morberg-Nguyen, 2026
        </p>
      </footer>
    </div>
    <script>
      import { initHashScroll } from '../scripts/hash-scroll.ts';

      initHashScroll();
      document.addEventListener('astro:page-load', () => {
        initHashScroll();
      });
    </script>
  </body>
</html>
