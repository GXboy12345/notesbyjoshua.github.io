---
import type { TreeNode } from '../lib/notes-tree';
import { pathActive } from '../lib/paths';

interface Props {
  nodes: TreeNode[];
  current: string;
  depth?: number;
}

const { nodes, current, depth = 0 } = Astro.props;
---

<ul class="notes-tree" data-depth={depth}>
  {
    nodes.map((node) => (
      <li class="notes-tree-item">
        {node.children.length > 0 ? (
          <details open={depth < 2}>
            <summary class="tree-summary">
              <span class="tree-caret" aria-hidden="true" />
              {node.href && node.path ? (
                <a
                  class="tree-link"
                  href={node.href}
                  aria-current={pathActive(current, node.path) ? 'page' : undefined}
                >
                  {node.label}
                </a>
              ) : (
                <span class="tree-label">{node.label}</span>
              )}
            </summary>
            <Astro.self nodes={node.children} current={current} depth={depth + 1} />
          </details>
        ) : node.href && node.path ? (
          <a
            class="tree-link tree-link--leaf"
            href={node.href}
            aria-current={pathActive(current, node.path) ? 'page' : undefined}
          >
            {node.label}
          </a>
        ) : (
          <span class="tree-label tree-link--leaf">{node.label}</span>
        )}
      </li>
    ))
  }
</ul>
