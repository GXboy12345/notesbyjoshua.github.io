<button
  type="button"
  class="cram-mode-toggle"
  data-cram-toggle
  aria-pressed="false"
  aria-label="Enable cram mode"
>
  Cram
</button>

<script>
  import { initCramMode, isCramMode, toggleCramMode } from '../scripts/cram-mode.ts';

  function syncCramToggle(btn: HTMLButtonElement) {
    const on = isCramMode();
    btn.setAttribute('aria-pressed', on ? 'true' : 'false');
    btn.setAttribute('aria-label', on ? 'Disable cram mode' : 'Enable cram mode');
  }

  function bindCramToggle() {
    initCramMode();

    const btn = document.querySelector<HTMLButtonElement>('[data-cram-toggle]');
    if (!btn || btn.dataset.cramToggleBound === '1') return;
    btn.dataset.cramToggleBound = '1';

    syncCramToggle(btn);

    btn.addEventListener('click', () => {
      toggleCramMode();
      syncCramToggle(btn);
    });

    document.addEventListener('astro:page-load', () => syncCramToggle(btn));
  }

  bindCramToggle();
  document.addEventListener('astro:page-load', bindCramToggle);
</script>
