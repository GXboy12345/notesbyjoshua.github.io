---
import { mainNav } from '../data/navigation';
import { p, pathActive } from '../lib/paths';
import HeaderSearch from './HeaderSearch.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  current?: string;
}

const { current = Astro.url.pathname } = Astro.props;
---

<header class="site-header" transition:persist="site-header">
  <a class="brand" href={p('/')}>Notes by <span>Joshua</span></a>
  <nav class="header-nav" aria-label="Primary">
    {
      mainNav.map((item) => (
        <a href={p(item.href)} aria-current={pathActive(current, item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="header-actions">
    <div id="ref-sheet-handle" class="ref-sheet-handle-slot" hidden></div>
    <HeaderSearch />
    <ThemeToggle />
  </div>
</header>

<script>
  import { pathActiveFromPathname } from '../lib/paths';

  function syncHeaderActive() {
    const nav = document.querySelector<HTMLElement>('.site-header .header-nav');
    if (!nav) return;
    const current = window.location.pathname;
    nav.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
      const linkPath = new URL(link.href, window.location.origin).pathname;
      if (pathActiveFromPathname(current, linkPath)) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  syncHeaderActive();
  document.addEventListener('astro:page-load', syncHeaderActive);
</script>
