---
import { mainNav } from '../data/navigation';
import { p, pathActive } from '../lib/paths';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  current?: string;
}

const { current = Astro.url.pathname } = Astro.props;
---

<header class="site-header" transition:persist="site-header">
  <a class="brand" href={p('/')}>Notes by <span>Joshua</span></a>
  <nav class="header-nav" aria-label="Primary">
    {
      mainNav.map((item) => (
        <a href={p(item.href)} aria-current={pathActive(current, item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="header-actions">
    <ThemeToggle />
    <button
      type="button"
      class="btn menu-toggle"
      hidden
      aria-expanded="true"
      aria-controls="doc-sidebar"
      aria-label="Toggle notes sidebar"
    >
      Sidebar
    </button>
  </div>
</header>

<script>
  import { initSidebar, syncSidebarActive } from '../scripts/sidebar.ts';

  initSidebar();
  syncSidebarActive();
  document.addEventListener('astro:page-load', () => {
    initSidebar();
    syncSidebarActive();
  });
</script>
