---
import { mainNav } from '../data/navigation';
import { p, pathActive } from '../lib/paths';
import HeaderSearch from './HeaderSearch.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  current?: string;
}

const { current = Astro.url.pathname } = Astro.props;
---

<header class="site-header" transition:persist="site-header">
  <a class="brand" href={p('/')}>Notes by <span>Joshua</span></a>
  <nav class="header-nav nav-slider-track" aria-label="Primary">
    {
      mainNav.map((item) => (
        <a
          href={p(item.href)}
          aria-current={pathActive(current, item.href) ? 'page' : undefined}
          data-nav-active={pathActive(current, item.href) ? '' : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="header-actions">
    <div id="ref-sheet-handle" class="ref-sheet-handle-slot" hidden></div>
    <HeaderSearch />
    <ThemeToggle />
  </div>
</header>

<script>
  import { initNavSlider, syncNavSlider, syncTrackActive } from '../scripts/nav-slider';

  function syncHeaderActive() {
    const nav = document.querySelector<HTMLElement>('.site-header .header-nav');
    if (!nav) return;
    syncTrackActive(nav);
    syncNavSlider(nav);
  }

  initNavSlider(document.querySelector('.site-header .header-nav'));
  syncHeaderActive();
  document.addEventListener('astro:page-load', syncHeaderActive);
</script>
