---
import { mainNav } from '../data/navigation';
import { p, pathActive } from '../lib/paths';
import { allDocEntries } from '../lib/resolve-doc';
import { buildNotesTree } from '../lib/notes-tree';
import NotesTree from './NotesTree.astro';

interface Props {
  current?: string;
}

const { current = Astro.url.pathname } = Astro.props;
const notesTree = buildNotesTree(await allDocEntries());
---

<aside id="doc-sidebar" class="doc-sidebar" aria-label="Section navigation">
  <nav class="sidebar-primary">
    {
      mainNav.map((item) => (
        <a href={p(item.href)} aria-current={pathActive(current, item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
  <p class="nav-section">Notes library</p>
  <NotesTree nodes={notesTree} current={current} />
</aside>
