---
import { mainNav, subjectHubs } from '../data/navigation';
import { p, pathActive } from '../lib/paths';
import { allDocEntries } from '../lib/resolve-doc';
import { buildNotesTree } from '../lib/notes-tree';
import NotesTree from './NotesTree.astro';

interface Props {
  current?: string;
}

const { current = Astro.url.pathname } = Astro.props;
const notesTree = buildNotesTree(await allDocEntries());
---

<div class="doc-sidebar-shell">
<div id="sidebar-backdrop" class="sidebar-backdrop" aria-hidden="true"></div>

<div class="doc-sidebar-column">
  <button
    type="button"
    class="sidebar-toggle sidebar-toggle--fab"
    aria-expanded="false"
    aria-controls="sidebar-inner"
    aria-label="Open notes menu"
  >
    <svg class="sidebar-toggle-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M5 5v14"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        opacity="0.55"></path>
      <path
        d="M9 6l6 6-6 6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>

  <div class="doc-sidebar-host">
  <aside
    id="doc-sidebar"
    class="doc-sidebar"
    aria-label="Section navigation"
    transition:persist="doc-sidebar"
  >
    <div class="sidebar-toolbar">
      <span class="sidebar-toolbar-label">Notes</span>
      <button
        type="button"
        class="sidebar-toggle sidebar-toggle--toolbar"
        aria-expanded="true"
        aria-controls="sidebar-inner"
        aria-label="Collapse notes sidebar"
      >
        <svg class="sidebar-toggle-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M15 6l-6 6 6 6"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M19 5v14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            opacity="0.55"></path>
        </svg>
      </button>
    </div>

    <div id="sidebar-inner" class="sidebar-inner">
      <nav class="sidebar-primary nav-slider-track" aria-label="Primary">
        {
          mainNav.map((item) => (
            <a
              class="sidebar-primary-link"
              href={p(item.href)}
              data-nav-active={pathActive(current, item.href) ? '' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <nav class="sidebar-hubs" aria-label="Subject hubs">
        {
          subjectHubs.map((hub) => (
            <a
              class="sidebar-hub"
              href={p(hub.href)}
              data-tone={hub.tone}
              aria-current={pathActive(current, hub.href) ? 'page' : undefined}
            >
              {hub.title}
            </a>
          ))
        }
      </nav>

      <div class="sidebar-divider" role="separator"></div>

      <p class="nav-section sidebar-section-label">Notes library</p>

      <div class="sidebar-tree-scroll">
        <NotesTree nodes={notesTree} current={current} />
      </div>
    </div>
  </aside>
  </div>
</div>
</div>

<script>
  import { initSidebar, syncSidebarActive } from '../scripts/sidebar.ts';
  import { initNavSlider, syncNavSlider, syncTrackActive } from '../scripts/nav-slider';

  function syncSidebarNav() {
    syncSidebarActive();
    const primary = document.querySelector<HTMLElement>('.sidebar-primary');
    if (primary) {
      syncTrackActive(primary);
      syncNavSlider(primary);
    }
  }

  document.addEventListener(
    'click',
    (e) => {
      const link = (e.target as Element).closest('[data-tree-nav]');
      if (link) e.stopPropagation();
    },
    true,
  );

  initNavSlider(document.querySelector('.sidebar-primary'));
  initSidebar();
  syncSidebarNav();
  document.addEventListener('astro:page-load', () => {
    initSidebar();
    syncSidebarNav();
  });
</script>
