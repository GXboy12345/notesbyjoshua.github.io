---
import { p } from '../lib/paths';
import { apCourses, statusLabel } from '../data/home';
---

<section class="home-section home-section--ap" id="ap-courses" aria-labelledby="ap-heading">
  <div class="home-ap-panel" data-ap-courses>
    <div class="home-ap-panel-top">
      <div class="home-ap-panel-intro">
        <h2 id="ap-heading">AP courses</h2>
        <p class="home-ap-meta">
          <span data-ap-total>{apCourses.length}</span> courses
        </p>
      </div>

      <div class="home-ap-search-wrap">
        <label class="home-ap-search" for="ap-filter">
          <span class="visually-hidden">Filter AP courses</span>
          <svg class="home-ap-search-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"></circle>
            <path d="M20 20l-4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
          </svg>
          <input
            id="ap-filter"
            class="home-ap-search-input"
            type="search"
            placeholder="Find a course"
            autocomplete="off"
            spellcheck="false"
            aria-controls="ap-list"
            aria-describedby="ap-filter-status"
          />
        </label>
        <button
          type="button"
          class="home-ap-search-clear"
          data-ap-clear
          hidden
          aria-label="Clear search"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M6 6l12 12M18 6L6 18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>

      <p class="home-ap-filter-status" id="ap-filter-status" data-ap-status aria-live="polite" aria-atomic="true" hidden></p>
    </div>

    <ul class="home-ap-list" id="ap-list">
      {
        apCourses.map((course) => (
          <li
            class="home-ap-item"
            data-search={course.course.toLowerCase()}
            data-status={course.status}
          >
            <a class="home-ap-link" href={p(course.href)}>
              <span class="home-ap-name">{course.course}</span>
              <span class="home-ap-units">{course.units}</span>
              <span class={`home-ap-status home-ap-status--${course.status}`}>
                {statusLabel[course.status]}
              </span>
              {course.detail && <span class="home-ap-detail">{course.detail}</span>}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <p class="home-section-foot">
    <a href={p('/notes/ap/')}>Open the AP hub</a>
  </p>
</section>

<script>
  function initHomeApCourses(root: HTMLElement) {
    if (root.dataset.apBound === '1') return;
    root.dataset.apBound = '1';

    const input = root.querySelector<HTMLInputElement>('.home-ap-search-input');
    const list = root.querySelector<HTMLUListElement>('.home-ap-list');
    const status = root.querySelector<HTMLElement>('[data-ap-status]');
    const clearBtn = root.querySelector<HTMLButtonElement>('[data-ap-clear]');

    if (!input || !list || !status) return;

    const items = [...list.querySelectorAll<HTMLElement>('.home-ap-item')];
    const total = items.length;

    const filter = () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      items.forEach((item) => {
        const match = !q || item.dataset.search?.includes(q);
        item.hidden = !match;
        if (match) visible += 1;
      });

      if (q === '') {
        status.textContent = '';
        status.hidden = true;
        root.classList.remove('home-ap-panel--filtered', 'home-ap-panel--empty');
      } else {
        status.textContent =
          visible === 0 ? `No courses match “${input.value.trim()}”` : `${visible} of ${total} courses`;
        status.hidden = false;
        root.classList.toggle('home-ap-panel--filtered', visible > 0);
        root.classList.toggle('home-ap-panel--empty', visible === 0);
      }

      if (clearBtn) clearBtn.hidden = q === '';
    };

    input.addEventListener('input', filter);
    clearBtn?.addEventListener('click', () => {
      input.value = '';
      filter();
      input.focus();
    });
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && input.value) {
        event.preventDefault();
        input.value = '';
        filter();
      }
    });
  }

  function bindHomeApCourses() {
    document.querySelectorAll<HTMLElement>('[data-ap-courses]').forEach(initHomeApCourses);
  }

  bindHomeApCourses();
  document.addEventListener('astro:page-load', bindHomeApCourses);
</script>
