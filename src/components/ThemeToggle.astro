<button type="button" class="theme-dial" data-theme-toggle aria-label="Toggle color theme">
  <span class="theme-dial-track" aria-hidden="true">
    <span class="theme-dial-sky"></span>
    <span class="theme-dial-sun"></span>
    <span class="theme-dial-moon"></span>
    <span class="theme-dial-knob"></span>
  </span>
</button>

<script>
  import { initTheme, toggleTheme } from '../scripts/theme.ts';

  function bindThemeToggle() {
    initTheme();

    const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    if (!btn || btn.dataset.themeToggleBound === '1') return;
    btn.dataset.themeToggleBound = '1';

    btn.addEventListener('click', () => {
      toggleTheme();
      btn.classList.remove('theme-dial--pulse');
      void btn.offsetWidth;
      btn.classList.add('theme-dial--pulse');
    });
  }

  bindThemeToggle();
  document.addEventListener('astro:page-load', bindThemeToggle);
</script>
