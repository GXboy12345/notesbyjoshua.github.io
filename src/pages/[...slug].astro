---
import DocLayout from '../layouts/DocLayout.astro';
import { routePath, routeSlug } from '../lib/routes';
import { allDocEntries, docBySlug } from '../lib/resolve-doc';
import { readDocSource, renderDoc } from '../lib/render-doc';
import { preprocessMarkdown } from '../lib/markdown-preprocess';

export async function getStaticPaths() {
  const docs = await allDocEntries();
  const seen = new Set<string>();

  return docs
    .map((entry) => {
      const slug = routeSlug(entry);
      if (!slug || slug === 'index') return null;
      if (seen.has(slug)) return null;
      seen.add(slug);
      return { params: { slug } };
    })
    .filter(Boolean);
}

const slug = Astro.params.slug ?? '';
const entry = await docBySlug(slug);
if (!entry) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const { body } = readDocSource(entry);
const md = preprocessMarkdown(body);
const isNotes = entry.collection === 'notes';
const pagePath = routePath(entry);
const { html, headings, contentHash } = renderDoc(md, {
  pageSlug: slug,
  injectPois: isNotes,
});
const title = entry.data.title ?? entry.id.replace(/\.md$/, '');
const isFeedback = entry.collection === 'siteFeedback';
const embedUrl =
  entry.collection === 'siteFeedback'
    ? (entry.data.feedback_form_embed_url ??
      'https://docs.google.com/forms/d/e/1FAIpQLSeV_8oTyDJ_Yycjq1r4GPXFNjka71Vg5LNjEh4iYJsn7bgaXQ/viewform?embedded=true')
    : undefined;
---

<DocLayout
  title={title}
  math={false}
  interactive={isNotes}
  annotations={isNotes}
  pageId={pagePath}
  pageTitle={title}
  contentHash={contentHash}
  headings={headings}
>
  <Fragment set:html={html} />
  {
    isFeedback && embedUrl && (
      <iframe
        class="feedback-embed"
        src={embedUrl}
        title="Feedback form"
        loading="lazy"
      >
        Loading form…
      </iframe>
    )
  }
</DocLayout>
