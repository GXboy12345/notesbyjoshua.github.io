---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contributor from '../components/about/Contributor.astro';
import TechStack from '../components/about/TechStack.astro';
import { contributors, techStack, upstreamRepo } from '../data/credits';
---

<BaseLayout
  title="Credits"
  description="Authors, maintainers, and technology behind Notes by Joshua."
>
  <main class="credits-page" transition:animate="fade">
    <header class="credits-header">
      <h1>Credits</h1>
      <p class="credits-lead">
        Notes by Joshua is a study site for AP, math, and physics. Content is by Joshua; the
        Astro frontend and deployment are maintained on a fork.
      </p>
    </header>

    <section class="credits-section" aria-labelledby="people-heading">
      <h2 id="people-heading" class="credits-section-title">People</h2>
      <div class="contributor-grid">
        {contributors.map((person) => <Contributor {...person} />)}
      </div>
    </section>

    <section class="credits-section" aria-labelledby="stack-heading">
      <TechStack items={techStack} />
    </section>

    <section class="credits-section credits-upstream" aria-labelledby="upstream-heading">
      <h2 id="upstream-heading" class="credits-section-title">Upstream</h2>
      <p>
        Note content and the original Jekyll site live in the upstream repository. This fork
        tracks the Astro migration and Pages deployment.
      </p>
      <p>
        <a href={upstreamRepo.href} target="_blank" rel="noopener noreferrer">
          {upstreamRepo.label}
        </a>
      </p>
    </section>
  </main>
</BaseLayout>
