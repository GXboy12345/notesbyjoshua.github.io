{
  "name": "notesbyjoshua",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "rm -rf node_modules/.vite && astro dev",
    "prebuild": "node scripts/build-frq-manifest.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "frq:manifest": "node scripts/build-frq-manifest.mjs",
    "worker:dev": "node scripts/build-frq-manifest.mjs && wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "node scripts/build-frq-manifest.mjs && wrangler deploy --config worker/wrangler.toml",
    "worker:secret": "wrangler secret put OPENROUTER_API_KEY --config worker/wrangler.toml",
    "lint:notes": "node scripts/lint-notes.mjs",
    "note:new": "node scripts/note-new.mjs",
    "codemod:theorem": "node scripts/codemod-theorem-box.mjs --write",
    "codemod:figure": "node scripts/codemod-figure.mjs --write",
    "codemod:chem-mcq": "node scripts/codemod-chem-mcq.mjs --write",
    "codemod:precalc-practice": "node scripts/codemod-precalc-practice.mjs",
    "codemod:all": "node scripts/codemod-theorem-box.mjs --write && node scripts/codemod-figure.mjs --write && node scripts/codemod-chem-mcq.mjs --write",
    "fix:fences": "node scripts/fix-orphan-fences.mjs --write",
    "fix:mcq-fences": "node scripts/fix-mcq-closing-fences.mjs --write",
    "fix:solutions": "node scripts/strip-duplicate-solutions.mjs --write",
    "search:diag": "npm run build && node --experimental-strip-types scripts/search-diagnostics.ts",
    "fix:solutions-stubs": "node scripts/remove-solutions-stubs.mjs --write"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/sitemap": "^3.3.1",
    "astro": "^5.7.10",
    "dexie": "^4.4.3",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.22",
    "marked": "^15.0.7",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0",
    "minisearch": "^7.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "wrangler": "^4.14.0"
  }
}
